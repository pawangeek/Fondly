# Fondly environment variables
# Copy to .env.local for local dev (use `vercel env pull` once linked) and set
# the same in the Vercel project dashboard.

# --- Supabase (Project Settings -> API) ---
# Client-exposed (safe — RLS allows read-only):
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR-ANON-OR-PUBLISHABLE-KEY

# Server-only (full access — used by /api/publish). NEVER prefix with VITE_:
SUPABASE_SECRET_KEY=YOUR-SERVICE-ROLE-OR-SECRET-KEY

# --- Vercel Blob ---
# Auto-injected when you create a Blob store and link it to the project.
# `@vercel/blob` reads BLOB_READ_WRITE_TOKEN automatically for put/del/upload.
# For local `vercel dev`, pull all of these with `vercel env pull`.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx
# Also added by the integration (not used directly by this app, leave as-is):
BLOB_STORE_ID=store_xxx
BLOB_WEBHOOK_PUBLIC_KEY=xxx

# --- Cron auth ---
# Set any random string. Vercel sends it as `Authorization: Bearer <value>` to
# scheduled invocations of /api/cron-cleanup; the function rejects others.
CRON_SECRET=generate-a-long-random-string
